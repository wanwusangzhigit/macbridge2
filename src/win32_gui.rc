#include "win32_gui.h"

101 DIALOGEX 0, 0, 500, 250
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "安装 DMG 应用"
FONT 8, "MS Shell Dlg", 0, 0, 0x0
BEGIN
    LTEXT "选择 DMG 文件:", -1, 10, 20, 100, 14
    EDITTEXT IDC_FILE_PATH, 10, 40, 380, 24, ES_READONLY | WS_BORDER | WS_TABSTOP
    PUSHBUTTON "浏览...", IDC_BROWSE_BTN, 400, 40, 80, 24, WS_TABSTOP
    LTEXT "状态:", -1, 10, 80, 50, 14
    STATIC IDC_INSTALL_STATUS, 60, 80, 400, 14, SS_LEFT
    CONTROL "", IDC_INSTALL_PROGRESS, "msctls_progress32", PBS_SMOOTH, 10, 110, 480, 20
    DEFPUSHBUTTON "安装", IDC_INSTALL_BTN, 180, 180, 70, 24, WS_TABSTOP
    PUSHBUTTON "取消", IDCANCEL, 260, 180, 70, 24, WS_TABSTOP
END

102 DIALOGEX 0, 0, 650, 400
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "已安装应用列表"
FONT 8, "MS Shell Dlg", 0, 0, 0x0
BEGIN
    CONTROL "", IDC_APP_LIST, "SysListView32", LVS_REPORT | LVS_SINGLESEL | WS_BORDER | WS_TABSTOP, 10, 10, 630, 330
    PUSHBUTTON "刷新", IDC_REFRESH_BTN, 250, 350, 70, 24, WS_TABSTOP
    PUSHBUTTON "关闭", IDCANCEL, 330, 350, 70, 24, WS_TABSTOP
END

103 DIALOGEX 0, 0, 600, 350
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "卸载应用"
FONT 8, "MS Shell Dlg", 0, 0, 0x0
BEGIN
    CONTROL "", IDC_UNINSTALL_LIST, "SysListView32", LVS_REPORT | LVS_SINGLESEL | WS_BORDER | WS_TABSTOP, 10, 10, 580, 270
    DEFPUSHBUTTON "卸载", IDOK, 220, 290, 70, 24, WS_TABSTOP
    PUSHBUTTON "取消", IDCANCEL, 310, 290, 70, 24, WS_TABSTOP
END

104 DIALOGEX 0, 0, 650, 400
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "DMG 文件信息"
FONT 8, "MS Shell Dlg", 0, 0, 0x0
BEGIN
    LTEXT "选择 DMG 文件:", -1, 10, 20, 100, 14
    EDITTEXT IDC_FILE_PATH, 10, 40, 480, 24, ES_READONLY | WS_BORDER | WS_TABSTOP
    PUSHBUTTON "浏览...", IDC_BROWSE_BTN, 500, 40, 80, 24, WS_TABSTOP
    EDITTEXT IDC_DMG_INFO_TEXT, 10, 80, 630, 270, ES_MULTILINE | ES_READONLY | WS_BORDER
    DEFPUSHBUTTON "分析", IDOK, 250, 360, 70, 24, WS_TABSTOP
    PUSHBUTTON "关闭", IDCANCEL, 330, 360, 70, 24, WS_TABSTOP
END

105 DIALOGEX 0, 0, 650, 400
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Mach-O 测试工具"
FONT 8, "MS Shell Dlg", 0, 0, 0x0
BEGIN
    LTEXT "选择 Mach-O 文件:", -1, 10, 20, 120, 14
    EDITTEXT IDC_FILE_PATH, 10, 40, 480, 24, ES_READONLY | WS_BORDER | WS_TABSTOP
    PUSHBUTTON "浏览...", IDC_BROWSE_BTN, 500, 40, 80, 24, WS_TABSTOP
    EDITTEXT IDC_MACHO_RESULT, 10, 80, 630, 270, ES_MULTILINE | ES_READONLY | WS_BORDER
    DEFPUSHBUTTON "测试", IDOK, 250, 360, 70, 24, WS_TABSTOP
    PUSHBUTTON "关闭", IDCANCEL, 330, 360, 70, 24, WS_TABSTOP
END
